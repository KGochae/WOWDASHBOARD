{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaseignore",
      "**/.*",
      ".git/**",
      ".wrangler/**",
      ".claude/**",
      "node_modules/**",
      "_dev/**",
      "css/backup/**",
      "data/backup/**",
      "data/raid/**",
      "recap_data/**",
      "lib/wow-model-viewer/.github/**",
      "data/raw_xml/**",
      "data/characters.json",
      "data/characters_pretty.json",
      "data/bis_wh_cache.json",
      "data/items_classic_tbc.json",
      "data/loon_bis.json",
      "data/tbca_bis.json",
      "data/tbca_bis_new.json",
      "data/tbc_talents.json.bak_20260428",
      "data/tbc_base_spells.json",
      "data/user_login_log.json",
      "data/itemsEra.json",
      "data/itemsEra.json.gz",
      "data/gearscore_log.json",
      "lib/wow-model-viewer/tests/**",
      "lib/wow-model-viewer/types/**",
      "lib/wow-model-viewer/jest.config.js",
      "lib/wow-model-viewer/package.json",
      "*.bat",
      "*.py",
      "*.log",
      "*.json.lock",
      "*.ndjson",
      "**/*.ndjson",
      "**/*.md",
      "**/*.ts",
      "serviceAccountKey.json",
      "cors.json",
      "package.json",
      "package-lock.json",
      "schema.json",
      "parse_items.js",
      "gearscore_log.json",
      "fetch_progress.json",
      "wowhead_cache.json",
      "enchant_report.json",
      "raw_xml_merged.json",
      "items_tbc.json",
      "items_parsed.json",
      "new_items_preview.json",
      "inven_classic_item.json",
      "inven_tbc_item.json",
      "js/constants.js",
      "js/core.js",
      "js/navigation.js",
      "js/data.js",
      "js/guild.js",
      "js/character.js",
      "js/stats.js",
      "js/skillstats.js",
      "js/items.js",
      "js/raid.js",
      "js/compare.js",
      "js/tooltips.js",
      "js/legal.js",
      "js/recap.js",
      "js/event.js",
      "js/worldcup.js",
      "js/raid_builder.js",
      "js/raid_synergy_data.js"
    ],
    "headers": [
      {
        "source": "/recap_data/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "/data/tbc_talents.json",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "/data/dim_appearance.json",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "/data/tbca_bis_updated.json",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      },
      {
        "source": "/data/notices.json",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300" }
        ]
      },
      {
        "source": "/data/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=600" }
        ]
      },
      {
        "source": "/images/**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|webp|png|gif)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800" }
        ]
      },
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
